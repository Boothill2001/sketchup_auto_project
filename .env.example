# Copy this to .env and fill in your keys
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini API Keys (Round-Robin rotation to bypass rate limits)
GEMINI_KEY=your_gemini_key_1_here
GEMINI_KEY_2=your_gemini_key_2_here
GEMINI_KEY_3=your_gemini_key_3_here
GEMINI_KEY_4=your_gemini_key_4_here
GEMINI_KEY_5=your_gemini_key_5_here

# Hugging Face
HF_API_KEY=your_huggingface_token_here
HF_API_KEY_2=your_huggingface_token_2_here
