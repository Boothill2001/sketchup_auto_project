# =============================================================================
# PDF to SketchUp LOD 300 — Environment Configuration
# Copy this file to .env and fill in your API keys.
# =============================================================================

# =============================================================================
# GEMINI API KEYS
#
# IMPORTANT: Each key MUST be from a DIFFERENT Google account / Cloud project
# to get a separate 20 RPD (requests per day) quota.
# Keys from the same project share a single quota pool.
#
# Free tier limits per key (per project):
#   - 5 RPM  (requests per minute)
#   - 20 RPD (requests per day)  ← pipeline uses ~40-60 per PDF
#
# With N keys from N separate accounts = N × 20 RPD total capacity.
# Example: 5 accounts = 100 RPD = enough for 2-3 full PDF runs per day.
#
# How to get a key:
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Sign in with a Google account that has NOT used Gemini API today
#   3. Click "Create API key" → copy the key
#   4. Repeat with different accounts for GEMINI_KEY_2, GEMINI_KEY_3, etc.
#
# Add as many keys as you have accounts. Unused entries are ignored.
# =============================================================================

#minhtri 2001 key
GEMINI_KEY_2="AIzaSyBgdivDzd6CCtJRlxJ6FjIyiCDeEToQlrY"
#Feeldx key
GEMINI_KEY="AIzaSyDbJD2di_j_OMIa9YWtN-SN9fiSbLS6D-A"
#MinhTri 22082001 key
GEMINI_KEY_3="AIzaSyB1gAa9mj5oDRxsTJ_kqg9AVBcqDJFW5VM"
#Nguyễn Hoàng Long key
